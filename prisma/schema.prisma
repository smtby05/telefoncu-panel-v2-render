generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String           @id @default(cuid())
  fullName       String
  username       String           @unique
  email          String           @unique
  phone          String?
  passwordHash   String
  role           String           @default("STAFF")
  active         Boolean          @default(true)
  failedAttempts Int              @default(0)
  lockedUntil    DateTime?
  lastLoginAt    DateTime?
  preferences    UserPreference[]
  permissions    UserPermission[]
  auditLogs      AuditLog[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model UserPreference {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     Json
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, key])
}

model UserPermission {
  id      String  @id @default(cuid())
  userId  String
  key     String
  enabled Boolean @default(false)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, key])
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id          String          @id @default(cuid())
  name        String
  phone       String
  address     String?
  note        String?
  devices     Device[]
  services    ServiceTicket[]
  receivables Receivable[]
  buySells    BuySell[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  @@index([phone])
}

model DeviceBrand {
  id        String        @id @default(cuid())
  name      String        @unique
  type      String
  models    DeviceModel[]
  createdAt DateTime      @default(now())
}

model DeviceModel {
  id                          String      @id @default(cuid())
  brandId                     String
  name                        String
  storageOptions              Json?
  ramOptions                  Json?
  colors                      Json?
  releaseYear                 Int?
  commonProblems              Json?
  estimatedSecondHandMinPrice Decimal?
  estimatedSecondHandMaxPrice Decimal?
  estimatedRepairCostMin      Decimal?
  estimatedRepairCostMax      Decimal?
  brand                       DeviceBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt
  @@unique([brandId, name])
}

model Device {
  id           String          @id @default(cuid())
  customerId   String?
  brand        String
  model        String
  storage      String?
  ram          String?
  color        String?
  imeiOrSerial String?
  customer     Customer?       @relation(fields: [customerId], references: [id])
  services     ServiceTicket[]
  images       DeviceImage[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  @@index([imeiOrSerial])
}

model ServiceTicket {
  id            String        @id @default(cuid())
  no            String        @unique
  customerId    String
  deviceId      String?
  branchId      String?
  status        String
  issue         String
  price         Decimal       @default(0)
  paid          Decimal       @default(0)
  warrantyDays  Int           @default(90)
  trackingToken String        @unique
  customer      Customer      @relation(fields: [customerId], references: [id])
  device        Device?       @relation(fields: [deviceId], references: [id])
  images        DeviceImage[]
  warranty      Warranty?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model DeviceImage {
  id                    String         @id @default(cuid())
  deviceId              String?
  serviceTicketId       String?
  buySellId             String?
  fileUrl               String
  extractedBrand        String?
  extractedModel        String?
  extractedImeiOrSerial String?
  extractedColor        String?
  extractedStorage      String?
  confidence            Float?
  device                Device?        @relation(fields: [deviceId], references: [id])
  serviceTicket         ServiceTicket? @relation(fields: [serviceTicketId], references: [id])
  buySell               BuySell?       @relation(fields: [buySellId], references: [id])
  createdAt             DateTime       @default(now())
}

model BuySell {
  id                     String        @id @default(cuid())
  customerId             String?
  purchaseCustomerId     String?
  saleCustomerId         String?
  deviceType             String
  brand                  String
  model                  String
  storage                String?
  ram                    String?
  color                  String?
  imeiOrSerial           String?
  condition              String
  purchasePrice          Decimal
  estimatedPurchasePrice Decimal?
  estimatedSalePrice     Decimal?
  targetSalePrice        Decimal?
  actualSalePrice        Decimal?
  minAcceptableSalePrice Decimal?
  repairCost             Decimal       @default(0)
  cleaningCost           Decimal       @default(0)
  accessoryCost          Decimal       @default(0)
  cargoCost              Decimal       @default(0)
  taxCost                Decimal       @default(0)
  otherCost              Decimal       @default(0)
  extraCost              Decimal       @default(0)
  totalCost              Decimal
  expectedProfit         Decimal?
  actualProfit           Decimal?
  profitRate             Decimal?
  daysInStock            Int?
  profitStatus           String
  purchaseDate           DateTime
  soldDate               DateTime?
  status                 String
  note                   String?
  customer               Customer?     @relation(fields: [customerId], references: [id])
  images                 DeviceImage[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  @@index([imeiOrSerial])
}

model MediaAttachment {
  id              String   @id @default(cuid())
  entityType      String
  entityId        String
  customerId      String?
  buySellId       String?
  serviceTicketId String?
  saleId          String?
  type            String
  fileName        String
  fileUrl         String
  mimeType        String
  size            Int
  description     String?
  uploadedById    String
  createdAt       DateTime @default(now())
  @@index([entityType, entityId])
}

model Expense {
  id                         String   @id @default(cuid())
  name                       String
  category                   String
  amount                     Decimal
  period                     String
  includeInProfitCalculation Boolean  @default(true)
  isPersonalExpense          Boolean  @default(false)
  note                       String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model CapitalAccount {
  id             String            @id @default(cuid())
  name           String
  initialCapital Decimal
  currentCapital Decimal
  ownerUserId    String
  note           String?
  movements      CapitalMovement[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model CapitalMovement {
  id               String         @id @default(cuid())
  capitalAccountId String
  type             String
  amount           Decimal
  description      String?
  userId           String
  capitalAccount   CapitalAccount @relation(fields: [capitalAccountId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
}

model CashAccount {
  id        String   @id @default(cuid())
  name      String
  branchId  String?
  currency  String
  balance   Decimal  @default(0)
  createdAt DateTime @default(now())
}

model CustomerRiskNote {
  id          String   @id @default(cuid())
  customerId  String
  level       String
  note        String
  createdById String
  createdAt   DateTime @default(now())
  @@index([customerId])
}

model Permission {
  id          String @id @default(cuid())
  key         String @unique
  description String
}

model RolePermission {
  id            String @id @default(cuid())
  role          String
  permissionKey String
  @@unique([role, permissionKey])
}

model Receivable {
  id         String   @id @default(cuid())
  customerId String
  title      String
  total      Decimal
  paid       Decimal  @default(0)
  dueDate    DateTime
  status     String
  customer   Customer @relation(fields: [customerId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Appointment {
  id           String   @id @default(cuid())
  customerName String
  phone        String
  date         DateTime
  status       String
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Supplier {
  id        String         @id @default(cuid())
  name      String
  phone     String?
  address   String?
  debts     SupplierDebt[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model SupplierDebt {
  id         String   @id @default(cuid())
  supplierId String
  title      String
  amount     Decimal
  paid       Decimal  @default(0)
  dueDate    DateTime?
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Warranty {
  id        String        @id @default(cuid())
  serviceId String        @unique
  startDate DateTime
  endDate   DateTime
  service   ServiceTicket @relation(fields: [serviceId], references: [id])
  createdAt DateTime      @default(now())
}

model MarketPrice {
  id         String   @id @default(cuid())
  brand      String
  model      String
  storage    String?
  ram        String?
  condition  String
  sourceName String
  sourceUrl  String?
  price      Decimal
  currency   String
  recordedAt DateTime
  note       String?
  @@index([brand, model, recordedAt])
}

model ExchangeRate {
  id         String   @id @default(cuid())
  code       String
  name       String
  buyRate    Decimal
  sellRate   Decimal
  source     String
  recordedAt DateTime
  @@index([code, recordedAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  user       User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  @@index([createdAt])
  @@index([entityType, entityId])
}

model HelpContent {
  id        String   @id @default(cuid())
  pageKey   String
  title     String
  content   String
  steps     Json
  language  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([pageKey, language])
}
